SET @search_text = '';
SET @date_filter   = 'all';   -- empty means ignore
SET @date_from   = '';
SET @date_to     = '';
SET @company     = 'VILLARAAG';
SET @lead_source = '';
SET @assigned_to = '';
SET @priority    = '';
SET @urgency     = '';


SELECT 
   
          m.*,
						s.Assign_To_MR_Main    AS Assigned_To,
                        s.NBD_CRR,
                        s.Transcription,
                        s.Lead_Relates_to_which_company  AS Company,
                        s.Name_of_User,
                        s.Phone_Number_of_User,
                        s.Email_of_User,
                        s.Country,
                        s.Urgency_YES_NO    AS Urgency,
                        s.Contact_Time,
                        s.Summary_of_Conversation,
                        s.Lead_Outcome,
                        s.Lead_Category,
                        s.Preferred_Way_to_Contact,
                        s.Timestamp_2,
                        s.Intent,
                        s.Priority,
                        s.status,
                        s.Enquiry_Status_Last
                    FROM master_buffer m
                    LEFT JOIN staging_buffer_new s
                      ON m.lead_id = s.Lead_id
WHERE 1=1
-- 🔍 SEARCH (include lead_id also 🔥)
AND (
    @search_text = '' 
    OR m.lead_id LIKE CONCAT('%', @search_text, '%')
    OR m.Name_of_Client LIKE CONCAT('%', @search_text, '%')
    OR m.Mobile LIKE CONCAT('%', @search_text, '%')
    OR m.Email_Id LIKE CONCAT('%', @search_text, '%')
    OR m.Subjects LIKE CONCAT('%', @search_text, '%')
)
-- 📅 👉 YAHAA DALNA HAI
-- 📅 DATE
AND (
    @date_filter = 'all'

    OR (@date_filter = 'today' 
        AND DATE(m.Timestamp) = CURDATE())

    OR (@date_filter = 'yesterday' 
        AND DATE(m.Timestamp) = CURDATE() - INTERVAL 1 DAY)

    OR (@date_filter = 'this_week' 
        AND YEARWEEK(m.Timestamp, 1) = YEARWEEK(CURDATE(), 1))

    OR (@date_filter = 'last_week' 
        AND YEARWEEK(m.Timestamp, 1) = YEARWEEK(CURDATE(), 1) - 1)

    OR (@date_filter = 'this_month' 
        AND MONTH(m.Timestamp) = MONTH(CURDATE()) 
        AND YEAR(m.Timestamp) = YEAR(CURDATE()))

    OR (@date_filter = 'last_month' 
        AND MONTH(m.Timestamp) = MONTH(CURDATE() - INTERVAL 1 MONTH)
        AND YEAR(m.Timestamp) = YEAR(CURDATE() - INTERVAL 1 MONTH))

    OR (@date_filter = 'this_year' 
        AND YEAR(m.Timestamp) = YEAR(CURDATE()))

    OR (@date_filter = 'last_year' 
        AND YEAR(m.Timestamp) = YEAR(CURDATE()) - 1)
OR (
    @date_filter = 'custom' 
    AND @date_from != '' 
    AND @date_to != ''
    AND m.Timestamp BETWEEN 
        CONCAT(@date_from, ' 00:00:00') 
        AND CONCAT(@date_to, ' 23:59:59')
          )
     )
-- 🏢 COMPANY
AND (
    @company = '' 
    OR s.Lead_Relates_to_which_company = @company
)
-- 📊 LEAD SOURCE
AND (
    @lead_source = '' 
    OR m.Verified_Source = @lead_source
)
-- 👤 ASSIGNED
AND (
    @assigned_to = '' 
    OR s.Assign_To_MR_Main = @assigned_to
)
-- 🎯 PRIORITY
AND (
    @priority = '' 
    OR s.Priority = @priority
)
-- ⚡ URGENCY
AND (
    @urgency = '' 
    OR s.Urgency_YES_NO = @urgency
)
ORDER BY m.Timestamp DESC;
