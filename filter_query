
SET @search_text = '';
SET @date_filter = 'all';
SET @date_from   = '';
SET @date_to     = '';
SET @company     = 'VILLARAAG';
SET @lead_source = '';
SET @assigned_to = '';
SET @priority    = '';
SET @urgency     = '';

SET @sql = "
SELECT 
    m.*,

    s.Assign_To_MR_Main,
    s.NBD_CRR,
    s.Transcription,
    s.Lead_Relates_to_which_company,
    s.Name_of_User,
    s.Phone_Number_of_User,
    s.Email_of_User,
    s.Country,
    s.Urgency_YES_NO,
    s.Contact_Time,
    s.Summary_of_Conversation,
    s.Lead_Outcome,
    s.Lead_Category,
    s.Preferred_Way_to_Contact,
    s.Timestamp_2,
    s.Intent,
    s.Priority,
    s.status,
    s.Enquiry_Status_Last

FROM master_buffer m
JOIN staging_buffer_new s 
    ON m.lead_id = s.Lead_id
WHERE 1=1
";

-- 🔥 Dynamic filters (NO OR → FAST)

SET @sql = CONCAT(@sql,

    -- 🏢 COMPANY
    IF(@company != '', 
        CONCAT(" AND s.Lead_Relates_to_which_company = '", @company, "'"), 
        ''),

    -- 👤 ASSIGNED
    IF(@assigned_to != '', 
        CONCAT(" AND s.Assign_To_MR_Main = '", @assigned_to, "'"), 
        ''),

    -- 🎯 PRIORITY
    IF(@priority != '', 
        CONCAT(" AND s.Priority = '", @priority, "'"), 
        ''),

    -- ⚡ URGENCY
    IF(@urgency != '', 
        CONCAT(" AND s.Urgency_YES_NO = '", @urgency, "'"), 
        ''),

    -- 📊 LEAD SOURCE
    IF(@lead_source != '', 
        CONCAT(" AND m.Verified_Source = '", @lead_source, "'"), 
        ''),

    -- 🔍 SEARCH
  IF(@search_text != '', 

    IF(@search_text REGEXP '^[0-9]+$', 
        CONCAT(" AND m.Mobile LIKE '", @search_text, "%'"),

    IF(@search_text LIKE '%@%', 
        CONCAT(" AND m.Email_Id LIKE '", @search_text, "%'"),

    IF(@search_text REGEXP '^[A-Za-z0-9_-]+$', 
        CONCAT(" AND m.lead_id LIKE '", @search_text, "%'"),

        CONCAT(" AND m.Name_of_Client LIKE '", @search_text, "%'")
    ))),

''),
    -- 📅 DATE FILTER
    IF(@date_filter = 'today', "
        AND m.Timestamp >= CURDATE()
        AND m.Timestamp < CURDATE() + INTERVAL 1 DAY
    ", ''),

    IF(@date_filter = 'yesterday', "
        AND m.Timestamp >= CURDATE() - INTERVAL 1 DAY
        AND m.Timestamp < CURDATE()
    ", ''),

    IF(@date_filter = 'this_week', "
        AND m.Timestamp >= DATE_SUB(CURDATE(), INTERVAL WEEKDAY(CURDATE()) DAY)
    ", ''),

    IF(@date_filter = 'this_month', "
        AND m.Timestamp >= DATE_FORMAT(CURDATE(), '%Y-%m-01')
    ", ''),

    IF(@date_filter = 'this_year', "
        AND m.Timestamp >= DATE_FORMAT(CURDATE(), '%Y-01-01')
    ", ''),

    IF(@date_filter = 'custom' AND @date_from != '' AND @date_to != '',
        CONCAT(" AND m.Timestamp BETWEEN '", @date_from, " 00:00:00' 
                AND '", @date_to, " 23:59:59'"), 
        '')
);

-- 🔥 ORDER + LIMIT (VERY IMPORTANT)
SET @sql = CONCAT(@sql, " ORDER BY m.Timestamp DESC");

-- 👀 DEBUG (optional)
SELECT @sql;

-- 🚀 EXECUTE
PREPARE stmt FROM @sql;
EXECUTE stmt;
DEALLOCATE PREPARE stmt;





